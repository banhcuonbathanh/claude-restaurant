{
	# Disable admin API in production (optional — remove for local dev)
	admin off
}

# Production domain — replace with your actual domain or use :80 for local
:80 {
	# Backend: API + webhooks
	handle /api/* {
		reverse_proxy be:8080
	}

	handle /webhooks/* {
		reverse_proxy be:8080
	}

	handle /health {
		reverse_proxy be:8080
	}

	# Frontend: everything else
	handle {
		reverse_proxy fe:3000
	}
}
