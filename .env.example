# ── Docker Compose (MySQL) ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_rootpass
MYSQL_PASSWORD=CHANGE_ME_banhcuonpass

# ── Backend ─────────────────────────────────────────────────────────────────

# Database — keep MYSQL_PASSWORD in sync above
DB_DSN=banhcuon:CHANGE_ME_banhcuonpass@tcp(mysql:3306)/banhcuon?parseTime=true&charset=utf8mb4

# Redis address — host:port, no scheme (see main.go: os.Getenv("REDIS_ADDR"))
REDIS_ADDR=redis:6379

# Server
PORT=8080
MIGRATIONS_DIR=/migrations

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=2592000

# Storage — local filesystem
STORAGE_BASE_URL=http://localhost:8080/uploads
STORAGE_BASE_PATH=/var/www/uploads

# VNPay — sandbox credentials from sandbox.vnpayment.vn
VNPAY_TMN_CODE=CHANGE_ME
VNPAY_HASH_SECRET=CHANGE_ME
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# MoMo — sandbox credentials from developers.momo.vn
MOMO_PARTNER_CODE=CHANGE_ME
MOMO_ACCESS_KEY=CHANGE_ME
MOMO_SECRET_KEY=CHANGE_ME
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ZaloPay — sandbox credentials from developers.zalopay.vn
ZALOPAY_APP_ID=CHANGE_ME
ZALOPAY_KEY1=CHANGE_ME
ZALOPAY_KEY2=CHANGE_ME
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create

# Webhook base URL — use ngrok for local: ngrok http 8080
WEBHOOK_BASE_URL=http://localhost:8080

# CORS
CORS_ORIGINS=http://localhost:3000

# ── Frontend ────────────────────────────────────────────────────────────────
# Baked at build time — also set as --build-arg in docker compose
NEXT_PUBLIC_API_URL=http://localhost:8080
